# Prisma datasource for @fammycomforts/db (AR4 — PostgreSQL 18).
# Copy to packages/db/.env (gitignored) for local `prisma migrate` / `prisma studio`.
# The API reads DATABASE_URL from its own environment (see apps/api config).
DATABASE_URL="postgresql://fammycomforts:fammycomforts@localhost:5432/fammycomforts?schema=public"
