# Convex deployment wiring (project: bry-code/sommycomfort).
# `npx convex dev` writes CONVEX_DEPLOYMENT here and prints the deployment URL.
#   Development deployment: quixotic-boar-465
#   Production deployment:  notable-cod-441
CONVEX_DEPLOYMENT=

# The web app consumes the deployment URL (see apps/web Convex provider wiring):
# NEXT_PUBLIC_CONVEX_URL=https://<deployment>.convex.cloud
